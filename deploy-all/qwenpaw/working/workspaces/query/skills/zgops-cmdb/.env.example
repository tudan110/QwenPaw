# 当前 CMDB 环境
VEOPS_BASE_URL=http://your-cmdb-host:8000
VEOPS_USERNAME=your_username
VEOPS_PASSWORD=your_password
# VEOPS_SESSION_NAME=cmdb

# 可选：INOE 网关下的 CMDB 统计接口，例如 /prod-api/cmdb/v0.1/ci/count/group
# 用于资源数量、状态、厂商/制造商分布等统计查询。
INOE_API_BASE_URL=http://your-inoe-host:30081/prod-api
# 可选：如果 CMDB 接口和其他 INOE 接口不是同一个网关地址，可单独覆盖。
# INOE_CMDB_API_BASE_URL=http://your-inoe-host:30081/prod-api
INOE_API_TOKEN=your_jwt_token_here
INOE_ENABLE_CURL_FALLBACK=true
# 可选：不同环境路径前缀不一致时再覆盖，默认就是 /cmdb/v0.1/...
# INOE_CMDB_TYPES_PATH=/cmdb/v0.1/ci_types
# INOE_CMDB_TYPE_GROUPS_PATH=/cmdb/v0.1/ci_types/groups
# INOE_CMDB_COUNT_PATH=/cmdb/v0.1/ci/count
# INOE_CMDB_COUNT_GROUP_PATH=/cmdb/v0.1/ci/count/group
# INOE_CMDB_COUNT_CHILD_PATH=/cmdb/v0.1/ci/count/child
# INOE_CMDB_COUNT_CHILD_GROUP_PATH=/cmdb/v0.1/ci/count/child/group
# INOE_CMDB_COUNT_GROUP_ATTR_PATH=/cmdb/v0.1/ci/count/group/attr

# 可选：仅当目标机器上的 Python 命令不是 python3 时再取消注释
# VEOPS_PYTHON_BIN=/usr/bin/python3

# 可选：资源导入时用于字段语义映射 / 图片抽取的 OpenAI 兼容模型配置
# RESOURCE_IMPORT_LLM_BASE_URL=http://127.0.0.1:11434/v1
# RESOURCE_IMPORT_LLM_API_KEY=your-api-key
# RESOURCE_IMPORT_LLM_MODEL=qwen2.5-72b-instruct
# RESOURCE_IMPORT_LLM_VISION_MODEL=qwen2.5-vl-72b-instruct
# RESOURCE_IMPORT_LLM_TIMEOUT=45

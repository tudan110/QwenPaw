    "clients": {
      "tavily_search": {
        "name": "tavily_mcp",
        "description": "",
        "enabled": false,
        "transport": "stdio",
        "url": "",
        "headers": {},
        "command": "npx",
        "args": [
          "-y",
          "tavily-mcp@latest"
        ],
        "env": {
          "TAVILY_API_KEY": ""
        },
        "cwd": ""
      }
    }
